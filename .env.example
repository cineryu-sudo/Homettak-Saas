# ── Google Gemini AI ──
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro

# ── 앱 환경 설정 ──
APP_ENV=development
APP_DEBUG=true

# ── KakaoTalk AlimTalk (리마인드 연동) ──
# true 로 설정하면 /api/reminders/kakao 가 실제 발송 API를 호출합니다.
KAKAO_ALIMTALK_ENABLED=false

# 카카오 알림톡 벤더사 발송 API 엔드포인트 (예: https://api.vendor.com/v1/alimtalk/send)
KAKAO_ALIMTALK_ENDPOINT=

# 벤더사 API 인증키
KAKAO_ALIMTALK_API_KEY=

# 카카오 채널 SenderKey
KAKAO_ALIMTALK_SENDER_KEY=

# 알림톡 템플릿 코드
KAKAO_ALIMTALK_TEMPLATE_CODE=
